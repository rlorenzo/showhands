# Copy to /opt/showhands/app/.env on the droplet (owner showhands, mode 600).
PORT=3002
ORIGIN=https://showhands.rexlorenzo.com
DATABASE_PATH=/opt/showhands/data/showhands.db
# 32+ chars. Set explicitly so device cookies and creator tokens survive even
# if the data directory is wiped (polls themselves are disposable by design).
SHOWHANDS_SECRET=change-me
